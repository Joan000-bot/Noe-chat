# ===== noe-chat 配置 =====

# OpenRouter API (必需 - 用于 AI 对话)
# 从 https://openrouter.ai/keys 获取
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# ElevenLabs (可选 - 用于语音合成)
# 从 https://elevenlabs.io/app/settings/api-keys 获取
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_AGENT_ID=

# Telegram Bot (可选 - 用于通知推送)
# 从 @BotFather 创建 bot 获取
TELEGRAM_BOT_TOKEN=
# 你的 chat id，可以从 @userinfobot 获取
TELEGRAM_CHAT_ID=

# 默认 AI 模型
DEFAULT_MODEL=google/gemma-3-27b-it:free
